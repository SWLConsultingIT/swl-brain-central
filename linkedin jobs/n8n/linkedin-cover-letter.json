      "id": "aaaa0006-bbbb-cccc-dddd-eeeeeeee0006",
      "name": "Fetch BU"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://uaefxpewxmvmhxpgehuv.supabase.co/rest/v1/proposals?status=eq.Sent&business_unit_id=eq.{{ $('Fetch this job').item.json.business_unit_id }}&order=sent_date.desc&limit=5&select=job_title,cover_letter,sent_date",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer <REPLACE_WITH_SUPABASE_SECRET_KEY>"
            },
            {
              "name": "apikey",
              "value": "<REPLACE_WITH_SUPABASE_SECRET_KEY>"
            }
          ]
        },
        "options": {
          "response": {
