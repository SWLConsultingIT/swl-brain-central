            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  p_job_id: $json.job_id,\n  p_to_status: 'proposal_drafted',\n  p_actor: 'brain_cover_letter',\n  p_actor_detail: 'claude-sonnet-4-5',\n  p_reason: 'cover letter drafted (' + $json.chars + ' chars)',\n  p_cover_letter_draft: $json.cover_letter\n}) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
